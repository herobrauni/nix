{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommitsDisabled"
  ],
  "timezone": "Europe/Berlin",
  "schedule": ["after 1am and before 4am"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["after 1am and before 4am"]
  },
  "packageRules": [
    {
      "matchManagers": [
        "github-actions",
        "dockerfile",
        "docker-compose",
        "npm",
        "pnpm",
        "yarn",
        "cargo",
        "gomod"
      ],
      "schedule": ["after 1am and before 4am"]
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest",
        "lockFileMaintenance"
      ],
      "automerge": true,
      "automergeType": "pr"
    }
  ]
}
